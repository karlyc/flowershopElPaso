# PostgreSQL connection string (Railway provides this automatically when you add a Postgres service)
DATABASE_URL="postgresql://user:password@localhost:5432/karels_flowers"

# Secret used to sign staff JWTs — set a long random string in production
JWT_SECRET="change-me"

# Server port (Railway sets this automatically)
PORT=3000

# Comma-separated list of allowed frontend origins (POS app, public site), or "*" for all
CORS_ORIGIN="*"

NODE_ENV=development
